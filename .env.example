# LLM provider: claude | ollama | lmstudio
LLM_PROVIDER=claude

# Optional: override model name for any provider
# LLM_MODEL=llama3
# LLM_MODEL=claude-sonnet-4-6
# LLM_MODEL=mistral

# Optional: override base URL (defaults shown below)
# LLM_BASE_URL=http://localhost:11434/v1   # ollama
# LLM_BASE_URL=http://localhost:1234/v1    # lmstudio

# --- Claude ---
ANTHROPIC_API_KEY=your_key_here

# --- Ollama (defaults, no changes needed if using standard port) ---
# OLLAMA_DEFAULT_MODEL=llama3

# --- LM Studio (defaults, no changes needed if using standard port) ---
# LMSTUDIO_DEFAULT_MODEL=local-model
