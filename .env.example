# LLM provider: claude | ollama | lmstudio
LLM_PROVIDER=claude

# Model name (defaults shown — override as needed)
# LLM_MODEL=claude-sonnet-4-6   # claude default
# LLM_MODEL=llama3               # ollama example
# LLM_MODEL=google/gemma-3-4b    # lmstudio example

# Base URL override (defaults shown)
# LLM_BASE_URL=http://localhost:11434/v1   # ollama
# LLM_BASE_URL=http://localhost:1234/v1    # lmstudio

# Max tokens in LLM response
LLM_MAX_TOKENS=512

# Context limit for small local models (0 = no limit)
# Set to ~200 less than your model's n_ctx to leave room for the response
# LLM_CONTEXT_LIMIT=4500   # for 4096-token models

# --- Claude ---
ANTHROPIC_API_KEY=your_key_here

# --- LM Studio ---
# LM_STUDIO_API_KEY=not-needed
